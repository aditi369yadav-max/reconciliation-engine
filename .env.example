# App
PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reconciliation_engine
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (also used for BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Reconciliation
RECONCILIATION_INTERVAL_MS=60000
MISMATCH_AUTO_RESOLVE_MINUTES=10
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000

# Simulation
BANK_MISMATCH_RATE=0.2
UPI_MISMATCH_RATE=0.15
PRODUCER_INTERVAL_MS=5000
