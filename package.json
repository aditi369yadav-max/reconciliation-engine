{
  "name": "reconciliation-engine",
  "version": "1.0.0",
  "description": "Distributed Transaction Reconciliation Engine",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node -e \"require('./dist/migrate-prod.js')\" && node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/reconciliationWorker.ts",
    "producer": "ts-node src/workers/transactionProducer.ts",
    "migrate": "ts-node db/migrate.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "bullmq": "^5.1.1",
    "axios": "^1.6.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1",
    "prom-client": "^15.1.0",
    "cors": "^2.8.5",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/cors": "^2.8.17"
  }
}
